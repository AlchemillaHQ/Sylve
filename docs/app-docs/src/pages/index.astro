---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/sections/Hero.astro";
import SylveExplainer from "@/components/sections/SylveExplainer.svelte";
import Sponsors from "@/components/sections/Sponsors.astro";
import Community from "@/components/sections/Community.astro";
import FAQ from "@/components/sections/FAQ.svelte";
---

<BaseLayout>
  <div class="relative pt-24">
    <Hero />
    <div class="relative py-12 px-4 sm:px-6 lg:px-8">
      <SylveExplainer client:load />
      <Sponsors />
      <FAQ client:load />
      <Community />
    </div>
  </div>
</BaseLayout>

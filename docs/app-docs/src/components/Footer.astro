---
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-border bg-background/70 backdrop-blur-lg">
  <div class="container mx-auto max-w-7xl px-6 py-10 md:py-12">
    <div
      class="grid grid-cols-1 gap-8 text-sm sm:grid-cols-2 lg:grid-cols-12 lg:gap-10"
    >
      <div class="sm:col-span-2 lg:col-span-5">
        <a href="/" class="inline-flex items-center gap-2">
          <span class="text-xl font-semibold tracking-tight">Sylve</span>
        </a>
        <p class="mt-3 max-w-md text-sm leading-relaxed text-muted-foreground">
          Sylve is a modern, lightweight web control panel for FreeBSD. Manage
          Bhyve VMs, Jails, and ZFS storage through one intuitive interface.
        </p>
      </div>

      <div class="grid gap-2 lg:col-span-2">
        <h3 class="text-sm font-semibold" data-i18n="pages">Pages</h3>
        <a
          href="/"
          class="text-muted-foreground transition-colors hover:text-foreground"
          data-i18n="home">Home</a
        >
        <a
          href="/blog"
          class="text-muted-foreground transition-colors hover:text-foreground"
          data-i18n="blog">Blog</a
        >
      </div>

      <div class="grid gap-2 lg:col-span-2">
        <h3 class="text-sm font-semibold" data-i18n="resources">Resources</h3>
        <a
          href="/docs/"
          class="text-muted-foreground transition-colors hover:text-foreground"
          data-i18n="documentation">Documentation</a
        >
        <a
          href="https://github.com/AlchemillaHQ/Sylve"
          class="text-muted-foreground transition-colors hover:text-foreground"
          data-i18n="support">Support</a
        >
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-sm font-semibold">Community</h3>
        <div class="mt-2 flex items-center gap-2">
          <a
            href="https://github.com/AlchemillaHQ/Sylve"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Sylve GitHub repo"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border/70 bg-background/80 text-muted-foreground transition-colors hover:text-foreground"
          >
            <span class="icon-[mdi--github] size-4.5"></span>
          </a>
          <a
            href="https://discord.gg/bJB826JvXK"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Sylve Discord community"
            class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-border/70 bg-background/80 text-muted-foreground transition-colors hover:text-foreground"
          >
            <span class="icon-[mdi--discord] size-4.5"></span>
          </a>
        </div>
      </div>
    </div>

    <div
      class="mt-8 flex flex-col items-center justify-between gap-3 border-t border-border/70 pt-5 text-sm text-muted-foreground md:flex-row"
    >
      <p>© {currentYear} Sylve. All rights reserved.</p>
      <div
        class="inline-flex items-center gap-2 rounded-full border border-border/70 bg-background/80 px-3 py-1.5 text-xs tracking-wide"
      >
        <span class="icon-[lucide--heart] size-3.5 text-red-500"></span>
        <span>Made with love in India</span>
      </div>
    </div>
  </div>
</footer>
